<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="7dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/app_border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Черновик"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:background="@color/app_primary_light"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Senior Backend Developer"
            android:textColor="@color/app_text"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/salaryTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="350000 - 700000 ₽"
            android:textColor="@color/app_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/formatTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Удалённо"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:background="@color/app_primary_light"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/overloadHintTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Отклики временно приостановлены из-за перегруза. Обработайте минимум 50% откликов, чтобы снова открыть вакансию."
            android:textColor="@color/app_error"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:background="@color/app_error_light"
            android:padding="12dp"
            android:visibility="gone"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp">

            <TextView
                android:id="@+id/viewsTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Просмотры: 0"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/applicationsTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Отклики: 0"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/publishButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Опубликовать"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/app_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/archiveButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="В архив"
                android:textAllCaps="false"
                android:textColor="@color/app_primary"
                app:cornerRadius="14dp"
                app:strokeColor="@color/app_primary"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/app_surface" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>