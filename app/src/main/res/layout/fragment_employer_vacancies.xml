<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Мои вакансии"
                android:textColor="@color/app_text"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Публикуйте вакансии и обрабатывайте отклики"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hiringResponsibilityCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/app_border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/app_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Индекс ответственного найма"
                        android:textColor="@color/app_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/hiringResponsibilityHintTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Следите за нагрузкой и своевременно обрабатывайте отклики."
                        android:textColor="@color/app_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/app_primary_light"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Активные"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/activeVacanciesTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/app_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/app_error_light"
                            android:padding="10dp"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="На паузе"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/pausedVacanciesTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/app_error"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/app_success_light"
                            android:padding="10dp"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Отклики"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/totalApplicationsTextView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/app_success"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_gravity="center"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/createVacancyButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Создать вакансию"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/app_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/employerProfileButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_gravity="end"
                        android:text="Профиль компании"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@color/app_primary"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/app_primary"
                        app:strokeWidth="1dp"
                        app:backgroundTint="@color/app_surface" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

        <TextView
            android:id="@+id/emptyTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вы пока не создали ни одной вакансии"
            android:textColor="@color/app_text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone"
            android:padding="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/employerVacanciesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>