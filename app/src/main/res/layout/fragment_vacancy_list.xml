<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/screenTitleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Вакансии"
        android:textColor="#1F1F29"
        android:textSize="30sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="8dp" />

    <EditText
        android:id="@+id/searchEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:hint="Поиск по названию"
        android:singleLine="true"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:background="@android:drawable/edit_text"
        android:paddingHorizontal="14dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        android:scrollbars="none">

        <RadioGroup
            android:id="@+id/workFormatRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <RadioButton
                android:id="@+id/allRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Все"
                android:checked="true" />

            <RadioButton
                android:id="@+id/remoteRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Удалённо" />

            <RadioButton
                android:id="@+id/hybridRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Гибрид" />

            <RadioButton
                android:id="@+id/officeRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Офис" />

            <RadioButton
                android:id="@+id/partTimeRadioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Подработка" />

        </RadioGroup>

    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/emptyTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Вакансии не найдены"
        android:textColor="#777783"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        android:padding="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/vacanciesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

</LinearLayout>