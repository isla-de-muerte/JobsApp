<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="7dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/app_border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kotlin Backend Developer"
            android:textColor="@color/app_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/salaryTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="150000 - 300000 ₽"
            android:textColor="@color/app_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/workFormatTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Удалённо"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:background="@color/app_primary_light"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/descriptionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Описание вакансии"
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>