<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="7dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/app_border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Новый"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:background="@color/app_primary_light"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/vacancyIdTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Senior Backend Developer"
            android:textColor="@color/app_text"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/unreadBadgeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@color/app_error"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:visibility="gone"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/coverLetterTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сопроводительное письмо"
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="10dp" />
        <TextView
            android:id="@+id/feedbackTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фидбэк работодателя"
            android:textColor="@color/app_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:visibility="gone"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/dateTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Дата отклика"
            android:textColor="@color/app_text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>