<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.jobsapp.presentation.splash.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splashFragment_to_vacancyListFragment"
            app:destination="@id/vacancyListFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splashFragment_to_employerVacanciesFragment"
            app:destination="@id/employerVacanciesFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.jobsapp.presentation.auth.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment_to_vacancyListFragment"
            app:destination="@id/vacancyListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_loginFragment_to_employerVacanciesFragment"
            app:destination="@id/employerVacanciesFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.jobsapp.presentation.auth.RegisterFragment"
        android:label="Register">

        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />

        <action
            android:id="@+id/action_registerFragment_to_vacancyListFragment"
            app:destination="@id/vacancyListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_registerFragment_to_employerVacanciesFragment"
            app:destination="@id/employerVacanciesFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/vacancyListFragment"
        android:name="com.example.jobsapp.presentation.vacancies.VacancyListFragment"
        android:label="Vacancies">

        <action
            android:id="@+id/action_vacancyListFragment_to_vacancyDetailsFragment"
            app:destination="@id/vacancyDetailsFragment" />

    </fragment>

    <fragment
        android:id="@+id/vacancyDetailsFragment"
        android:name="com.example.jobsapp.presentation.vacancies.VacancyDetailsFragment"
        android:label="Vacancy details">

        <argument
            android:name="vacancyId"
            app:argType="string" />

    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.jobsapp.presentation.profile.ProfileFragment"
        android:label="Profile" />

    <fragment
        android:id="@+id/applicationsFragment"
        android:name="com.example.jobsapp.presentation.applications.ApplicationsFragment"
        android:label="Applications" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.jobsapp.presentation.favorites.FavoritesFragment"
        android:label="Favorites">

        <action
            android:id="@+id/action_favoritesFragment_to_vacancyDetailsFragment"
            app:destination="@id/vacancyDetailsFragment" />

    </fragment>

    <fragment
        android:id="@+id/employerVacanciesFragment"
        android:name="com.example.jobsapp.presentation.employer.EmployerVacanciesFragment"
        android:label="Employer vacancies">

        <action
            android:id="@+id/action_employerVacanciesFragment_to_createVacancyFragment"
            app:destination="@id/createVacancyFragment" />

        <action
            android:id="@+id/action_employerVacanciesFragment_to_employerApplicationsFragment"
            app:destination="@id/employerApplicationsFragment" />

        <action
            android:id="@+id/action_employerVacanciesFragment_to_employerProfileFragment"
            app:destination="@id/employerProfileFragment" />

    </fragment>

    <fragment
        android:id="@+id/createVacancyFragment"
        android:name="com.example.jobsapp.presentation.employer.CreateVacancyFragment"
        android:label="Create vacancy" />

    <fragment
        android:id="@+id/employerApplicationsFragment"
        android:name="com.example.jobsapp.presentation.employer.EmployerApplicationsFragment"
        android:label="Employer applications">

        <argument
            android:name="vacancyId"
            app:argType="string" />

        <argument
            android:name="vacancyTitle"
            app:argType="string" />

    </fragment>

    <fragment
        android:id="@+id/employerProfileFragment"
        android:name="com.example.jobsapp.presentation.employer.EmployerProfileFragment"
        android:label="Employer profile" />

    <fragment
        android:id="@+id/applicationChatFragment"
        android:name="com.example.jobsapp.presentation.chat.ApplicationChatFragment"
        android:label="Application chat">

        <argument
            android:name="applicationId"
            app:argType="string" />

        <argument
            android:name="title"
            app:argType="string" />

    </fragment>

</navigation>